# Copy to pipeline/.env.local and fill in (never commit .env.local)

# --- Zotero (reuse the same credentials as app/editor) ---
ZOTERO_USER_ID=your_user_id
ZOTERO_API_KEY=your_api_key

# --- PubMed E-utilities (optional, raises rate limit from 3 to 10 req/s) ---
NCBI_API_KEY=
NCBI_EMAIL=you@example.com

# --- RAG RETRIEVER (semantic search over Zotero + local PDFs). NOT a text generator. ---
# Returns ranked chunks that are fed as CONTEXT into the synthesize stage; generation
# stays on the LLM backend below. Enabled via the 'retriever' section in config/backends.json.
# Finalized contract (FastAPI, port 8503; LIVE):
#   POST http://192.168.10.101:8503/query
#   body {"query":"...","limit":5,"year_filter":"2024"?,"source_filter":"zotero"|"chunks"?}
#   resp {"status":"success","results":[
#          {"id","title","content","year":"2024","source":"zotero"|"chunk","similarity":0.895}, ...]}
#   backend: multilingual-e5-base + pgvector; similarity >= 0.4; sorted desc.
#   (year_filter / source_filter defaults live in config/backends.json -> retriever;
#    a chapter brief's rag_year_filter / rag_source_filter overrides them per-run.)
RAG_QUERY_URL=http://192.168.10.101:8503/query
RAG_QUERY_API_KEY=
RAG_QUERY_LIMIT=5
RAG_MIN_SIMILARITY=0.0

# --- LLM backend (NotebookLM replacement). Provider chosen in config/backends.json ---
# Remote research machine = 192.168.10.101 (n8n UI :5678, RAG Streamlit UI :8502).
# NOTE: :8502 is the Streamlit UI (serves HTML), NOT a JSON API. Do not point the
# adapters at :8502. The RETRIEVER JSON API is :8503/query (see RAG_QUERY_URL above).

# rag_openai_compat: OpenAI-compatible server (RAG PC / Ollama / LM Studio / vLLM)
RAG_OPENAI_BASE_URL=http://192.168.10.101:11434/v1
RAG_OPENAI_API_KEY=
RAG_OPENAI_MODEL=

# rag_custom_rest: GENERATOR endpoint that returns a finished answer (NOT the retriever
# above). Only set this if you expose a generate-style API. Leave as-is otherwise.
RAG_CUSTOM_URL=http://192.168.10.101:8000/query
RAG_CUSTOM_API_KEY=

# google_pro: Gemini (Google AI Pro)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# --- Image backend (BioRender-style figures). Provider chosen in config/backends.json ---
# gemini_imagen uses GEMINI_API_KEY above
IMAGEN_MODEL=imagen-3.0-generate-002
